@article{Mishra.PNS,
title = {Polyhedral control-net splines for analysis},
journal = {Computers \& Mathematics with Applications},
volume = {151},
pages = {215-221},
year = {2023},
issn = {0898-1221},
doi = {https://doi.org/10.1016/j.camwa.2023.09.041},
url = {https://www.sciencedirect.com/science/article/pii/S0898122123004261},
author = {Bhaskar Mishra and Jörg Peters},
keywords = {Spline with polyhedral control net, Elliptic partial differential equations on free-form surfaces, -sided face, -junction, Polar layout, Higher-order isoparametric Galerkin analysis},
abstract = {Generalizing tensor-product splines to smooth functions whose control nets can outline more general topological polyhedra, bi-cubic polyhedral-net splines form a first-order differentiable piecewise polynomial space. Each polyhedral control net node is associated with one bi-cubic function. A polyhedral control net admits grid-, star-, n-gon-, polar- and three types of T-junction configurations. Analogous to tensor-product splines, polyhedral-net splines can both model curved geometry and represent higher-order functions on the geometry. This paper explores the use of polyhedral-net splines for solving elliptic partial differential equations on curved smooth free-form surfaces without additional meshing.}
}

